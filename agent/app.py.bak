"""FastAPI BFF for the Safety Intelligence Bot front-end.

- /chat  POST { "session_id": "...", "message": "..." }  -> streams agent reply.
- /healthz  GET  -> liveness.

All Azure auth uses managed identity (DefaultAzureCredential). No API keys.
"""
from __future__ import annotations

import asyncio
import json
import logging
from contextlib import asynccontextmanager

from fastapi import FastAPI, HTTPException
from fastapi.responses import StreamingResponse
from pydantic import BaseModel

from agent import build_agent

logging.basicConfig(level=logging.INFO)
log = logging.getLogger("safety-intel-bot")

_AGENT = None
_SESSIONS: dict[str, list] = {}


@asynccontextmanager
async def lifespan(app: FastAPI):
    global _AGENT
    _AGENT = build_agent()
    log.info("Agent built; tools=%s", [t.name for t in _AGENT.tools])
    yield


app = FastAPI(title="Safety Intelligence Bot", lifespan=lifespan)


class ChatIn(BaseModel):
    session_id: str
    message: str


@app.get("/healthz")
async def healthz() -> dict[str, str]:
    return {"status": "ok"}


@app.post("/chat")
async def chat(body: ChatIn):
    if _AGENT is None:
        raise HTTPException(503, "Agent not ready")
    history = _SESSIONS.setdefault(body.session_id, [])

    async def stream():
        try:
            async for event in _AGENT.run_stream(body.message, history=history):
                # Emit SSE-style chunks the front-end can route to chat / canvas.
                payload = {
                    "type": event.type,           # text | tool_call | tool_result | chart | final
                    "data": event.data,
                }
                yield f"data: {json.dumps(payload)}\n\n"
                await asyncio.sleep(0)
        except Exception as e:  # noqa: BLE001
            log.exception("agent run failed")
            yield f"data: {json.dumps({'type': 'error', 'data': str(e)})}\n\n"

    return StreamingResponse(stream(), media_type="text/event-stream")
